      "parameters": {
        "formTitle": "Form",
        "formFields": {
          "values": [
            {
              "fieldType": "html",
              "html": "<!-- OSK Property — Sales Gallery Walk-In Visitor Form: Intro Section -->\n<!-- Tailwind CSS utility classes only. No <style>, <script>, <input>, or inline styles. -->\n\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=DM+Sans:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n<link href=\"https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css\" rel=\"stylesheet\">\n\n<section class=\"min-h-screen bg-gray-100 flex items-center justify-center py-12 px-6\">\n\n  <div class=\"bg-white w-full max-w-2xl rounded-sm shadow-2xl overflow-hidden\">\n\n    <!-- Header -->\n    <div class=\"bg-black px-12 pt-9 pb-0 flex flex-col items-start gap-5\">\n\n      <img\n        src=\"/mnt/user-data/uploads/1773824080039_image.png\"\n        alt=\"OSK Property\"\n        class=\"h-14 w-auto object-contain\"\n      >\n\n      <div class=\"text-xs font-medium tracking-widest uppercase border-l-2 border-yellow-700 pl-3 pb-6 text-yellow-700\">\n        Sales Gallery &nbsp;·&nbsp; Visitor Registration\n      </div>\n\n      <div class=\"w-full h-1 bg-gradient-to-r from-yellow-700 to-transparent -mt-1\"></div>\n    </div>\n\n    <!-- Body -->\n    <div class=\"px-12 pt-10 pb-10\">\n\n      <!-- Title -->\n      <h1 class=\"text-4xl font-medium text-gray-900 leading-tight mb-2\" style=\"font-family:'Cormorant Garamond',serif;\">\n        Welcome to Our<br>\n        <span class=\"text-yellow-700\">Sales Gallery</span>\n      </h1>\n\n      <p class=\"text-sm text-gray-500 tracking-wide mb-6\">\n        Walk-In Visitor Registration Form\n      </p>\n\n      <!-- Divider -->\n      <div class=\"w-10 h-px bg-yellow-700 mb-6\"></div>\n\n      <!-- Intro -->\n      <p class=\"text-sm leading-relaxed text-gray-500 mb-8\">\n        Thank you for visiting us today. To assist you better and connect you with the right\n        property consultant, we kindly request a moment of your time to complete this short\n        registration form. Your details allow our team to personalise your experience and\n        follow up with relevant information on our current and upcoming developments.\n      </p>\n\n      <!-- Info pills -->\n      <div class=\"flex flex-wrap gap-2 mb-8\">\n\n        <div class=\"flex items-center gap-2 bg-gray-100 border border-gray-200 px-3 py-2 rounded-sm text-xs font-medium text-gray-800\">\n          <svg class=\"w-3.5 h-3.5 text-yellow-700 flex-shrink-0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\">\n            <circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/>\n          </svg>\n          Takes ~2 minutes\n        </div>\n\n        <div class=\"flex items-center gap-2 bg-gray-100 border border-gray-200 px-3 py-2 rounded-sm text-xs font-medium text-gray-800\">\n          <svg class=\"w-3.5 h-3.5 text-yellow-700 flex-shrink-0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\">\n            <rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"/>\n          </svg>\n          Secure &amp; Confidential\n        </div>\n\n        <div class=\"flex items-center gap-2 bg-gray-100 border border-gray-200 px-3 py-2 rounded-sm text-xs font-medium text-gray-800\">\n          <svg class=\"w-3.5 h-3.5 text-yellow-700 flex-shrink-0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\">\n            <path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/>\n            <path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/>\n          </svg>\n          Personal Consultant Assigned\n        </div>\n\n      </div>\n\n      <!-- PDPA Notice -->\n      <div class=\"bg-yellow-50 border border-yellow-200 border-l-4 border-l-yellow-700 rounded-sm p-5\">\n\n        <div class=\"flex items-center gap-2 text-xs font-medium tracking-widest uppercase text-yellow-700 mb-3\">\n          <svg class=\"w-3.5 h-3.5 flex-shrink-0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\">\n            <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>\n          </svg>\n          Personal Data Protection Notice (PDPA)\n        </div>\n\n        <p class=\"text-xs leading-relaxed text-yellow-900\">\n          Pursuant to the <strong>Personal Data Protection Act 2010 (Malaysia)</strong>, OSK Property Holdings Berhad\n          and its related companies (\"OSK Property\") collect and process the personal data you provide in this form\n          for the purposes of visitor management, property consultancy services, and follow-up communications\n          regarding our developments and promotional offers.\n          <br><br>\n          Your data will be kept secure and will not be disclosed to third parties without your consent, except\n          as required by law. You have the right to access or correct your personal data at any time. By proceeding\n          to complete this form, you <strong>consent</strong> to the collection and processing of your personal data\n          as described above and in accordance with our\n          <a href=\"https://oskproperty.com.my/privacy-policy\" target=\"_blank\" rel=\"noopener\" class=\"underline text-yellow-800\">\n            Privacy Policy\n          </a>.\n        </p>\n\n      </div>\n\n    </div>\n\n  </div>\n\n</section>"
            }
          ]
        },

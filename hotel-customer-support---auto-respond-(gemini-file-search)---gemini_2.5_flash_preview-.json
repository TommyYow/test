    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const content = $input.item.json.content;\n\n// Guard against empty/undefined Gemini response (safety filter or API error)\nif (!content || !content.parts || content.parts.length === 0) {\n  return {\n    json: {\n      ...$input.item.json,\n      language_detected: 'unknown',\n      ai_response: '',\n      status: 'skipped'\n    }\n  };\n}\n\nconst parts = content.parts;\n\n// Safely find the HTML reply part (contains <p> and LANGUAGE_DETECTED)\nconst replyPart = parts.find(p => \n  p.text && \n  p.text.includes('<p>') && \n  p.text.includes('LANGUAGE_DETECTED')\n) || parts[2] || parts[1]; // fallback\n\nlet output = replyPart ? replyPart.text : '';\n\n// Strip *** BEGIN/END FINAL REPLY *** markers — extract only the reply content\nconst finalReplyMatch = output.match(/\\*{3}\\s*BEGIN FINAL REPLY\\s*\\*{3}([\\s\\S]*?)\\*{3}\\s*END FINAL REPLY\\s*\\*{3}/);\nif (finalReplyMatch) {\n  output = finalReplyMatch[1].trim();\n}\n\n// Extract language\nconst langMatch = output.match(/LANGUAGE_DETECTED:\\s*(.+)/);\nconst language_detected = langMatch ? langMatch[1].trim() : 'English';\n\n// Remove the LANGUAGE_DETECTED tag from the HTML\nconst ai_response = output.replace(/LANGUAGE_DETECTED:.+/, '').trim();\n\nreturn {\n  json: {\n    ...$input.item.json,\n    language_detected,\n    ai_response,\n    status: 'sent'\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1968,
        2224
      ],
      "id": "d05ae789-643f-4abb-94ca-4ebff11dc218",
      "name": "Code in JavaScript - Gemini FS",
      "alwaysOutputData": true,
      "notesInFlow": true,
      "notes": "Guard — If Gemini returned empty/undefined response, skip processing and pass through with blank ai_response and language_detected: 'unknown'\nExtract — Find the correct reply part from Gemini's raw response, specifically the section between *** BEGIN FINAL REPLY *** and *** END FINAL REPLY ***, stripping away any leaked prompt instructions\nParse — Pull out the LANGUAGE_DETECTED tag from the reply, then remove it from the final HTML so it doesn't appear in the email sent to the customer"
    },
